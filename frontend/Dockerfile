FROM node:20-alpine AS builder
WORKDIR /app

ARG NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
ARG NEXT_PUBLIC_AUTH_MODE=local
ARG NEXT_PUBLIC_COGNITO_DOMAIN=
ARG NEXT_PUBLIC_COGNITO_CLIENT_ID=
ARG NEXT_PUBLIC_COGNITO_REDIRECT_URI=http://localhost:3000/auth/callback
ARG NEXT_PUBLIC_COGNITO_LOGOUT_URI=http://localhost:3000/login
ARG NEXT_PUBLIC_COGNITO_SCOPE="openid email profile"
ENV NEXT_PUBLIC_API_BASE_URL=$NEXT_PUBLIC_API_BASE_URL
ENV NEXT_PUBLIC_AUTH_MODE=$NEXT_PUBLIC_AUTH_MODE
ENV NEXT_PUBLIC_COGNITO_DOMAIN=$NEXT_PUBLIC_COGNITO_DOMAIN
ENV NEXT_PUBLIC_COGNITO_CLIENT_ID=$NEXT_PUBLIC_COGNITO_CLIENT_ID
ENV NEXT_PUBLIC_COGNITO_REDIRECT_URI=$NEXT_PUBLIC_COGNITO_REDIRECT_URI
ENV NEXT_PUBLIC_COGNITO_LOGOUT_URI=$NEXT_PUBLIC_COGNITO_LOGOUT_URI
ENV NEXT_PUBLIC_COGNITO_SCOPE=$NEXT_PUBLIC_COGNITO_SCOPE
ENV NEXT_TELEMETRY_DISABLED=1

COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build

FROM node:20-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME=0.0.0.0
ENV NEXT_TELEMETRY_DISABLED=1
ENV NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
ENV NEXT_PUBLIC_AUTH_MODE=local
ENV NEXT_PUBLIC_COGNITO_DOMAIN=
ENV NEXT_PUBLIC_COGNITO_CLIENT_ID=
ENV NEXT_PUBLIC_COGNITO_REDIRECT_URI=http://localhost:3000/auth/callback
ENV NEXT_PUBLIC_COGNITO_LOGOUT_URI=http://localhost:3000/login
ENV NEXT_PUBLIC_COGNITO_SCOPE="openid email profile"

COPY package*.json ./
RUN npm ci --omit=dev

COPY --from=builder /app/.next ./.next
COPY --from=builder /app/public ./public
COPY --from=builder /app/next.config.ts ./next.config.ts

EXPOSE 3000

CMD ["npm", "run", "start"]
