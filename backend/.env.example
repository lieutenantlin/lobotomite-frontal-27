AWS_DDB_SAMPLES_TABLE=Samples
AWS_DDB_DEVICES_TABLE=Devices
AWS_DDB_USER_PROFILES_TABLE=UserProfiles
AWS_DDB_AUDIT_LOGS_TABLE=AuditLogs
